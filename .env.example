# === Abrasel Monitor Legislativo - Environment Variables ===

# --- AWS ---
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_BRONZE=abrasel-monitor-bronze
S3_BUCKET_SILVER=abrasel-monitor-silver

# --- Database (PostgreSQL - Gold Layer) ---
DATABASE_URL=postgresql+asyncpg://abrasel:abrasel@localhost:5432/monitor_legislativo

# --- DynamoDB (Checkpoints) ---
DYNAMODB_TABLE_CHECKPOINTS=abrasel-monitor-checkpoints

# --- Alertas ---
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#monitor-legislativo
SES_SENDER_EMAIL=monitor@abrasel.com.br
SES_RECIPIENT_EMAILS=relacoes.institucionais@abrasel.com.br

# --- Rate Limiting ---
CAMARA_RATE_LIMIT_RPS=1.0
SENADO_RATE_LIMIT_RPS=1.0
ASSEMBLEIA_RATE_LIMIT_RPS=0.5

# --- Configuracao ---
KEYWORDS_CONFIG_PATH=config/keywords.yaml
LOG_LEVEL=INFO

# --- MCP Brasil (opcional - para discovery de ferramentas via LLM) ---
ANTHROPIC_API_KEY=
MCP_BRASIL_TOOL_SEARCH=bm25
